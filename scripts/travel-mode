#!/bin/bash
# Travel Mode - Battery optimization for hybrid NVIDIA laptops
# Inspired by envycontrol's integrated mode approach.
#
# Enable:  Blacklists NVIDIA modules, removes GPU from PCI bus via udev,
#          sets CPU powersave 2 GHz, disables turbo/bluetooth, lowers brightness.
# Disable: Restores EVERYTHING to the exact saved state.
#
# Usage: travel-mode {enable|disable|apply-boot|status}

STATE_DIR="/etc/travel-mode-state"
FLAG="/etc/travel-mode-active"
BACKLIGHT="/sys/class/backlight/intel_backlight"

BLACKLIST_PATH="/etc/modprobe.d/travel-mode-nvidia.conf"
UDEV_REMOVE_PATH="/etc/udev/rules.d/50-travel-mode-remove-nvidia.rules"

BLACKLIST_CONTENT='# Generated by Travel Mode

blacklist nouveau
blacklist nova_core
blacklist nova_drm
blacklist nvidia
blacklist nvidia_drm
blacklist nvidia_uvm
blacklist nvidia_modeset
blacklist i2c_nvidia_gpu
alias nouveau off
alias nova_core off
alias nova_drm off
alias nvidia off
alias nvidia_drm off
alias nvidia_uvm off
alias nvidia_modeset off
alias i2c_nvidia_gpu off
'

UDEV_REMOVE_CONTENT='# Generated by Travel Mode
# Physically remove NVIDIA devices from PCI bus and power them off.

# Remove NVIDIA USB xHCI Host Controller devices, if present
ACTION=="add", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", ATTR{class}=="0x0c0330", ATTR{power/control}="auto", ATTR{remove}="1"

# Remove NVIDIA USB Type-C UCSI devices, if present
ACTION=="add", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", ATTR{class}=="0x0c8000", ATTR{power/control}="auto", ATTR{remove}="1"

# Remove NVIDIA Audio devices, if present
ACTION=="add", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", ATTR{class}=="0x040300", ATTR{power/control}="auto", ATTR{remove}="1"

# Remove NVIDIA VGA/3D controller devices
ACTION=="add", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", ATTR{class}=="0x03[0-9]*", ATTR{power/control}="auto", ATTR{remove}="1"
'

# Progress output: STEP|percent|message
step() {
    echo "STEP|${1}|${2}"
}

save_state() {
    mkdir -p "$STATE_DIR"
    cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor > "$STATE_DIR/governor" 2>/dev/null
    cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq > "$STATE_DIR/max_freq" 2>/dev/null
    cat "$BACKLIGHT/brightness" > "$STATE_DIR/brightness" 2>/dev/null
    cat /proc/sys/vm/laptop_mode > "$STATE_DIR/laptop_mode" 2>/dev/null
    cat /proc/sys/vm/dirty_writeback_centisecs > "$STATE_DIR/dirty_writeback" 2>/dev/null
    cat /sys/devices/system/cpu/intel_pstate/no_turbo > "$STATE_DIR/turbo" 2>/dev/null
    powerprofilesctl get > "$STATE_DIR/power_profile" 2>/dev/null
    rfkill list bluetooth | grep -q "Soft blocked: yes" \
        && echo "blocked" > "$STATE_DIR/bluetooth" \
        || echo "unblocked" > "$STATE_DIR/bluetooth"
    for f in \
        /etc/udev/rules.d/61-mutter-primary-gpu.rules \
        /etc/environment.d/10-nvidia-session.conf \
        /etc/modprobe.d/nvidia.conf \
    ; do
        [ -f "$f" ] && cp "$f" "$STATE_DIR/$(basename "$f")"
    done
    systemctl is-enabled nvidia-max-perf.service > "$STATE_DIR/nvidia-max-perf-enabled" 2>/dev/null
    systemctl is-enabled nvidia-persistenced.service > "$STATE_DIR/nvidia-persistenced-enabled" 2>/dev/null
}

enable_travel() {
    if [ -f "$FLAG" ]; then
        echo "Travel Mode is already active."
        exit 0
    fi

    step 5 "Saving current system state..."
    save_state

    step 15 "Blacklisting NVIDIA kernel modules..."
    echo "$BLACKLIST_CONTENT" > "$BLACKLIST_PATH"

    step 25 "Creating udev rule to remove GPU from PCI bus..."
    echo "$UDEV_REMOVE_CONTENT" > "$UDEV_REMOVE_PATH"

    step 30 "Removing NVIDIA compositor configs..."
    rm -f /etc/udev/rules.d/61-mutter-primary-gpu.rules
    rm -f /etc/environment.d/10-nvidia-session.conf

    step 35 "Disabling NVIDIA services..."
    systemctl stop nvidia-powerd.service 2>/dev/null
    systemctl stop nvidia-persistenced.service 2>/dev/null
    systemctl stop nvidia-max-perf.service 2>/dev/null
    systemctl disable nvidia-max-perf.service 2>/dev/null
    systemctl disable nvidia-persistenced.service 2>/dev/null

    step 40 "Setting CPU to powersave (2.0 GHz, turbo off)..."
    for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
        echo powersave > "$cpu" 2>/dev/null
    done
    for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_max_freq; do
        echo 2000000 > "$cpu" 2>/dev/null
    done
    echo 1 > /sys/devices/system/cpu/intel_pstate/no_turbo 2>/dev/null

    step 50 "Setting power profile to power-saver..."
    powerprofilesctl set power-saver 2>/dev/null

    step 55 "Disabling Bluetooth..."
    rfkill block bluetooth 2>/dev/null

    step 58 "Lowering brightness to 40%..."
    if [ -f "$BACKLIGHT/max_brightness" ]; then
        MAX=$(cat "$BACKLIGHT/max_brightness")
        echo $((MAX * 40 / 100)) > "$BACKLIGHT/brightness"
    fi

    step 62 "Applying kernel power optimizations..."
    echo 5 > /proc/sys/vm/laptop_mode 2>/dev/null
    echo 1500 > /proc/sys/vm/dirty_writeback_centisecs 2>/dev/null
    echo 1 > /sys/module/snd_hda_intel/parameters/power_save 2>/dev/null
    for iface in /sys/class/net/e*; do
        ethtool -s "$(basename "$iface")" wol d 2>/dev/null
    done

    step 65 "Creating boot service..."
    cat > /etc/systemd/system/travel-mode-boot.service << 'UNIT'
[Unit]
Description=Travel Mode Boot Power Configuration
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/travel-mode apply-boot
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
UNIT
    systemctl daemon-reload
    systemctl enable travel-mode-boot.service

    step 70 "Rebuilding initramfs (this takes a moment)..."
    dracut --force --regenerate-all 2>/dev/null

    step 95 "Setting travel mode flag..."
    touch "$FLAG"

    step 100 "Travel Mode enabled. Ready to reboot."
}

disable_travel() {
    if [ ! -f "$FLAG" ]; then
        echo "Travel Mode is not active."
        exit 0
    fi

    step 5 "Removing NVIDIA blacklist..."
    rm -f "$BLACKLIST_PATH"

    step 10 "Removing GPU PCI removal rule..."
    rm -f "$UDEV_REMOVE_PATH"

    step 20 "Restoring NVIDIA config files..."
    for f in 61-mutter-primary-gpu.rules 10-nvidia-session.conf nvidia.conf; do
        if [ -f "$STATE_DIR/$f" ]; then
            case "$f" in
                61-mutter-primary-gpu.rules) cp "$STATE_DIR/$f" /etc/udev/rules.d/"$f" ;;
                10-nvidia-session.conf)      cp "$STATE_DIR/$f" /etc/environment.d/"$f" ;;
                nvidia.conf)                 cp "$STATE_DIR/$f" /etc/modprobe.d/"$f" ;;
            esac
        fi
    done

    step 30 "Restoring NVIDIA services..."
    if [ -f "$STATE_DIR/nvidia-persistenced-enabled" ] && grep -q "enabled" "$STATE_DIR/nvidia-persistenced-enabled"; then
        systemctl enable nvidia-persistenced.service 2>/dev/null
    fi
    if [ -f "$STATE_DIR/nvidia-max-perf-enabled" ] && grep -q "enabled" "$STATE_DIR/nvidia-max-perf-enabled"; then
        systemctl enable nvidia-max-perf.service 2>/dev/null
    fi

    step 35 "Removing boot service..."
    systemctl disable travel-mode-boot.service 2>/dev/null
    rm -f /etc/systemd/system/travel-mode-boot.service
    systemctl daemon-reload

    step 45 "Restoring CPU settings..."
    if [ -f "$STATE_DIR/governor" ]; then
        GOV=$(cat "$STATE_DIR/governor")
        for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
            echo "$GOV" > "$cpu" 2>/dev/null
        done
    fi
    if [ -f "$STATE_DIR/max_freq" ]; then
        FREQ=$(cat "$STATE_DIR/max_freq")
        for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_max_freq; do
            echo "$FREQ" > "$cpu" 2>/dev/null
        done
    fi
    [ -f "$STATE_DIR/turbo" ] && cat "$STATE_DIR/turbo" > /sys/devices/system/cpu/intel_pstate/no_turbo 2>/dev/null

    step 55 "Restoring power profile..."
    [ -f "$STATE_DIR/power_profile" ] && powerprofilesctl set "$(cat "$STATE_DIR/power_profile")" 2>/dev/null

    step 60 "Restoring Bluetooth..."
    if [ -f "$STATE_DIR/bluetooth" ] && [ "$(cat "$STATE_DIR/bluetooth")" = "unblocked" ]; then
        rfkill unblock bluetooth 2>/dev/null
    fi

    step 65 "Restoring brightness..."
    [ -f "$STATE_DIR/brightness" ] && cat "$STATE_DIR/brightness" > "$BACKLIGHT/brightness" 2>/dev/null

    step 68 "Restoring kernel parameters..."
    [ -f "$STATE_DIR/laptop_mode" ] && cat "$STATE_DIR/laptop_mode" > /proc/sys/vm/laptop_mode 2>/dev/null
    [ -f "$STATE_DIR/dirty_writeback" ] && cat "$STATE_DIR/dirty_writeback" > /proc/sys/vm/dirty_writeback_centisecs 2>/dev/null

    step 70 "Rebuilding initramfs with NVIDIA (this takes a moment)..."
    dracut --force --regenerate-all 2>/dev/null

    step 95 "Cleaning up..."
    rm -f "$FLAG"
    rm -rf "$STATE_DIR"

    step 100 "Travel Mode disabled. Ready to reboot."
}

apply_boot() {
    [ ! -f "$FLAG" ] && exit 0
    for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
        echo powersave > "$cpu" 2>/dev/null
    done
    for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_max_freq; do
        echo 2000000 > "$cpu" 2>/dev/null
    done
    echo 1 > /sys/devices/system/cpu/intel_pstate/no_turbo 2>/dev/null
    powerprofilesctl set power-saver 2>/dev/null
    echo 5 > /proc/sys/vm/laptop_mode 2>/dev/null
    echo 1500 > /proc/sys/vm/dirty_writeback_centisecs 2>/dev/null
    rfkill block bluetooth 2>/dev/null
    echo 1 > /sys/module/snd_hda_intel/parameters/power_save 2>/dev/null
    if [ -f "$BACKLIGHT/max_brightness" ]; then
        MAX=$(cat "$BACKLIGHT/max_brightness")
        echo $((MAX * 40 / 100)) > "$BACKLIGHT/brightness"
    fi
}

status() {
    [ -f "$FLAG" ] && echo "active" || echo "inactive"
}

force_reboot() {
    # Hard reboot: skips all inhibitors and doesn't wait for apps
    systemctl reboot --force
}

case "${1:-}" in
    enable)  enable_travel ;;
    disable) disable_travel ;;
    apply-boot) apply_boot ;;
    force-reboot) force_reboot ;;
    status)  status ;;
    *)
        echo "Usage: travel-mode {enable|disable|force-reboot|status}"
        exit 1
        ;;
esac
